# mgj-spark 环境变量示例（Spark / Ubuntu 24.04 aarch64）
# 用法：cp .env.spark.example .env  然后按需改；start.sh 会自动 source。
# 说明：这些是「运维态观测」端点与大模型行为的旋钮；飞书/大模型凭证在 config/credentials.json。

# ---- spark_ops 观测的服务端点（本机跑就用 localhost）----
COMFY_URL=http://127.0.0.1:8188          # aeon-spark ComfyUI（生图引擎）
AIGC_URL=http://127.0.0.1:8265           # AIGC-spark 生图工作台
SPARK_DEPLOY_DIR=~/spark-deploy          # spark-keeper 落 status.json/deploy.log 的目录

# ---- 生图（spark_gen 插件；复用 AIGC-spark 已在 Spark 跑通的 ComfyUI 客户端）----
COMFY_PROFILE=aeon-spark                  # 模型档位：aeon-spark=Klein-9B(Spark默认) | aki=Windows秋叶包(本机测试)
# FLUX_VARIANT=                           # 置 dev 走 Flux.2 Dev + Turbo-LoRA；默认空=Klein-9B
MGJ_OUT_DIR=~/mgj-spark/out               # 出图落盘目录
MGJ_GEN_TIMEOUT=600                       # 单次出图超时(秒)
# 逐项覆盖模型文件名（可选，不设走档位默认）：FLUX_UNET= / FLUX_CLIP= / FLUX_VAE=

# ---- 大模型行为 ----
# STEPFUN_API_KEY=                       # 也可用环境变量给 key（优先级高于 credentials.json）
MGJ_DEFAULT_MODEL=stepfun                # 默认模型规格；也可写 stepfun:step-3.7-flash / deepseek 等
MGJ_LLM_TIMEOUT=90                       # 单发补全超时(秒)

# ---- 飞书通道（也可在 config/registry.json 的 settings.feishu_channel 配）----
# 无需在此设；默认读 registry.json（http）。
